{
  "version": "0.1.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Debug Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run FastAPI local",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
          "ttc_server.main:app",
          "--reload",
          "--host",
          "0.0.0.0",
          "--port",
          "8001"
      ],
      "console": "integratedTerminal",
    },
      {
      "name": "Run Streamlit",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
          "run",
          "client/ttc_client/app.py",
          "--server.address",
          "0.0.0.0",
          "--server.port",
          "8502"
      ],
      "console": "integratedTerminal",
    }
  ]
}
